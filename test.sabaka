import "base/fraction.sabaka";

DecimalFraction d1 = new DecimalFraction(1, 50);  
DecimalFraction d2 = new DecimalFraction(-0, 75);
DecimalFraction d3 = d1.add(d2);      
DecimalFraction d4 = d1.multiply(d2); 

d3.print(); 
d4.print(); 


Fraction f1 = new Fraction(10, 20); 
Fraction f2 = new Fraction(1, 3);
Fraction f3 = f1.add(f2);          
Fraction f4 = f1.divide(f2);       

f1.print(); 
f3.print(); 
f4.print(); 

MixedFraction m1 = new MixedFraction(1, 2, 4);  
MixedFraction m2 = new MixedFraction(-2, 1, 2); 
MixedFraction m3 = m1.add(m2);                 

DecimalFraction mD = m2.toDecimal();

m3.toFraction().print(); 
mD.print();             

DecimalFraction finalD = f3.toDecimal();
finalD.print();
